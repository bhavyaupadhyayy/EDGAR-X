# ── SEC EDGAR ─────────────────────────────────────────────────────────────
# SEC requires a descriptive User-Agent with a contact email on every request.
EDGAR_USER_AGENT="EDGAR-X research bot (contact: you@example.com)"

# ── FRED (Federal Reserve Economic Data) ──────────────────────────────────
FRED_API_KEY=

# ── Polygon.io ────────────────────────────────────────────────────────────
POLYGON_API_KEY=

# ── Reddit (asyncpraw) ────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="edgar-x:v0.1 (by /u/your_reddit_username)"

# ── Kafka / Schema Registry ───────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Hot cache ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Airflow / local Postgres (docker-compose) ─────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
AIRFLOW_UID=50000
# Comma-separated ticker universe used by ingestion DAGs until the Layer 2
# universe mart exists.
EDGAR_X_UNIVERSE=AAPL,MSFT,NVDA,AMZN,GOOGL

# ── Alerting ──────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Anthropic / cost control (used from Layer 4 onward) ───────────────────
ANTHROPIC_API_KEY=
DAILY_SPEND_CAP_USD=50
# Hard per-run ceiling for the agent layer (Layer 4)
AGENT_SPEND_CAP_USD=5.00

# ── Snowflake (used from Layer 2 onward) ──────────────────────────────────
SNOWFLAKE_ACCOUNT=SSILLRP-BW82999
SNOWFLAKE_USER=BHAVAYUPADHYAY
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=EDGAR_X
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=RAW

# ── Pinecone (used from Layer 4 onward) ───────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=edgar-x
